NODE_ENV=production
OPS_PORT=3100
OPS_WEBHOOK_TOKEN=troque-por-um-token-longo-e-aleatorio
OPS_OUTBOX_TOKEN=troque-por-outro-token-longo-e-aleatorio
APP_VERSION=local
# Ative somente atras de um proxy reverso confiavel.
TRUST_PROXY=false
GCTECH_FIREBASE_CONFIG_PATH=/app/firebase-applet-config.json
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/firebase-service-account.json
# Alternative:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
